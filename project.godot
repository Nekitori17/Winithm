; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=4

[application]

config/name="Winithm"
run/main_scene="res://Winithm.Client/Scenes/Main.tscn"
run/delta_sync_after_draw=true
boot_splash/bg_color=Color( 0.141176, 0.141176, 0.141176, 0 )
config/icon="res://icon.png"

[autoload]

ScreenManager="*res://Winithm.Client/Scripts/Managers/ScreenManager.cs"

[display]

window/size/width=1280
window/size/height=720
window/size/resizable=false
window/size/borderless=true
window/dpi/allow_hidpi=true
window/per_pixel_transparency/allowed=true
window/per_pixel_transparency/enabled=true
window/stretch/aspect="expand"

[gui]

common/drop_mouse_on_gui_input_disabled=true
theme/use_hidpi=true

[input_devices]

pointing/emulate_touch_from_mouse=true
pointing/emulate_mouse_from_touch=false

[mono]

project/assembly_name="Winithm"

[node]

name_num_separator=3

[physics]

common/enable_pause_aware_picking=true
2d/thread_model=2

[rendering]

quality/driver/driver_name="GLES2"
2d/options/use_nvidia_rect_flicker_workaround=true
threads/thread_model=2
misc/lossless_compression/force_png=true
quality/filters/use_nearest_mipmap_filter=true
batching/precision/uv_contract=true
2d/options/culling_mode=0
environment/default_clear_color=Color( 0.301961, 0.301961, 0.301961, 0 )
viewport/transparent_background=true
environment/default_environment="res://default_env.tres"
